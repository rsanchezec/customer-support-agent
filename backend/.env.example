# Foundry configuration (mirror from example/.env)
FOUNDRY_PROJECT_ENDPOINT="https://your-foundry-project.services.ai.azure.com/api/projects/your-project-default"
AZURE_AI_AGENT_NAME="customer-support-agent"
FOUNDRY_MODEL="gpt-5-mini"

# Agent version. Leave empty to auto-detect the latest published version.
AGENT_VERSION=

# Application environment
APP_ENV=dev

# Database (SQLite for dev; swap to postgresql+asyncpg for prod)
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Entra ID (needed for JWT validation in slices 3+)
ENTRA_TENANT_ID="your-tenant-id"
ENTRA_CLIENT_ID="your-client-id"
ENTRA_APP_AUDIENCE="api://your-client-id"

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173
